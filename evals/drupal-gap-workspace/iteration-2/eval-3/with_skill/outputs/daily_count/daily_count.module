<?php

/**
 * @file
 * Daily Count module hooks.
 */

use Drupal\Core\Logger\LoggerChannelFactoryInterface;

/**
 * Implements hook_cron().
 */
function daily_count_cron(): void {
  $query = \Drupal::entityQuery('node')
    ->condition('type', 'article')
    ->condition('status', 1)
    ->accessCheck(FALSE)
    ->getQuery();

  $count_query = \Drupal::entityQuery('node')
    ->condition('type', 'article')
    ->condition('status', 1)
    ->accessCheck(FALSE)
    ->count();

  $count = $count_query->execute();

  \Drupal::state()->set('daily_count.article_count', $count);
  \Drupal::state()->set('daily_count.last_run', \Drupal::time()->getRequestTime());

  \Drupal::logger('daily_count')->info('Daily count: @count published articles.', ['@count' => $count]);
}
