<?php

/**
 * @file
 * Auto Slug module hooks.
 */

use Drupal\node\NodeInterface;

/**
 * Implements hook_node_presave().
 */
function auto_slug_node_presave(NodeInterface $node): void {
  if ($node->hasField('field_slug') && $node->get('field_slug')->isEmpty()) {
    $title = $node->getTitle();
    if ($title) {
      $slug = \Drupal::service('pathauto.alias_cleaner')
        ? mb_strtolower(preg_replace('/[^a-z0-9]+/i', '-', $title))
        : mb_strtolower(preg_replace('/[^a-z0-9]+/i', '-', $title));
      $node->set('field_slug', trim($slug, '-'));
    }
  }
}
