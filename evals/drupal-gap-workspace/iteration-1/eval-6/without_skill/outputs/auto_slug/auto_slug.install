<?php

/**
 * @file
 * Install, update, and uninstall functions for the Auto Slug module.
 */

use Drupal\field\Entity\FieldStorageConfig;
use Drupal\field\Entity\FieldConfig;

/**
 * Implements hook_install().
 */
function auto_slug_install(): void {
  // Create field storage for field_slug if it doesn't exist.
  if (!FieldStorageConfig::loadByName('node', 'field_slug')) {
    FieldStorageConfig::create([
      'field_name' => 'field_slug',
      'entity_type' => 'node',
      'type' => 'string',
      'settings' => [
        'max_length' => 255,
      ],
      'cardinality' => 1,
    ])->save();
  }

  // Create field instance on the Article bundle if it doesn't exist.
  if (!FieldConfig::loadByName('node', 'article', 'field_slug')) {
    FieldConfig::create([
      'field_name' => 'field_slug',
      'entity_type' => 'node',
      'bundle' => 'article',
      'label' => 'Slug',
      'description' => 'Auto-generated URL-friendly slug from the title.',
      'required' => FALSE,
      'settings' => [],
    ])->save();
  }
}

/**
 * Implements hook_uninstall().
 */
function auto_slug_uninstall(): void {
  // Remove the field instance from the Article bundle.
  $field_config = FieldConfig::loadByName('node', 'article', 'field_slug');
  if ($field_config) {
    $field_config->delete();
  }

  // Remove the field storage.
  $field_storage = FieldStorageConfig::loadByName('node', 'field_slug');
  if ($field_storage) {
    $field_storage->delete();
  }
}
